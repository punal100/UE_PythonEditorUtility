{
  "TabLabel": "Blender UV Fixer Pipeline",
  "StatusFile": "BlenderUvFixerPipelineStatus.txt",
  "StateFile": "BlenderUvFixerPipelineState.json",
  "InitPyCmd": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.refresh_status()",
  "Root": {
    "SVerticalBox": {
      "Slots": [
        {
          "AutoHeight": true,
          "SBorder": {
            "Padding": [10, 10, 10, 10],
            "Content": {
              "STextBlock": {
                "Text": "Example Blender UV Fixer Pipeline tab shaped like the live project: source and destination paths, selectable unwrap modes for UV 0 and UV 1, and an optional Blender executable override."
              }
            }
          }
        },
        {
          "AutoHeight": true,
          "SHorizontalBox": {
            "Slots": [
              {
                "AutoWidth": true,
                "Padding": [0, 0, 6, 6],
                "SButton": {
                  "Text": "Refresh",
                  "OnClick": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.refresh_status()"
                }
              },
              {
                "AutoWidth": true,
                "Padding": [0, 0, 6, 6],
                "SButton": {
                  "Text": "Run UV Fixer",
                  "OnClick": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.run_pipeline()"
                }
              },
              {
                "AutoWidth": true,
                "Padding": [0, 0, 6, 6],
                "SButton": {
                  "Text": "Open Source Folder",
                  "OnClick": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.open_source_folder()"
                }
              },
              {
                "AutoWidth": true,
                "SButton": {
                  "Text": "Open Destination Folder",
                  "OnClick": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.open_destination_folder()"
                }
              }
            ]
          }
        },
        {
          "AutoHeight": true,
          "Padding": [0, 0, 0, 6],
          "SHorizontalBox": {
            "Slots": [
              {
                "AutoWidth": true,
                "Padding": [0, 0, 8, 0],
                "STextBlock": { "Text": "Source Folder" }
              },
              {
                "FillWidth": 1.0,
                "Padding": [0, 0, 6, 0],
                "SEditableTextBox": {
                  "Aka": "SourceFolder",
                  "StateKey": "source_folder",
                  "Text": "",
                  "OnTextCommitted": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.set_paths(%Widget:SourceFolder%, %Widget:DestinationFolder%, %Widget:BlenderExecutable%)"
                }
              },
              {
                "AutoWidth": true,
                "SButton": {
                  "Text": "Browse",
                  "OnClick": "PEU:BrowseFolder:SourceFolder"
                }
              }
            ]
          }
        },
        {
          "AutoHeight": true,
          "Padding": [0, 0, 0, 6],
          "SHorizontalBox": {
            "Slots": [
              {
                "AutoWidth": true,
                "Padding": [0, 0, 8, 0],
                "STextBlock": { "Text": "Destination Folder" }
              },
              {
                "FillWidth": 1.0,
                "Padding": [0, 0, 6, 0],
                "SEditableTextBox": {
                  "Aka": "DestinationFolder",
                  "StateKey": "destination_folder",
                  "Text": "",
                  "OnTextCommitted": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.set_paths(%Widget:SourceFolder%, %Widget:DestinationFolder%, %Widget:BlenderExecutable%)"
                }
              },
              {
                "AutoWidth": true,
                "SButton": {
                  "Text": "Browse",
                  "OnClick": "PEU:BrowseFolder:DestinationFolder"
                }
              }
            ]
          }
        },
        {
          "AutoHeight": true,
          "Padding": [0, 0, 0, 6],
          "SHorizontalBox": {
            "Slots": [
              {
                "AutoWidth": true,
                "Padding": [0, 0, 8, 0],
                "STextBlock": { "Text": "Blender Executable" }
              },
              {
                "FillWidth": 1.0,
                "Padding": [0, 0, 6, 0],
                "SEditableTextBox": {
                  "Aka": "BlenderExecutable",
                  "StateKey": "blender_executable",
                  "Text": "",
                  "OnTextCommitted": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.set_paths(%Widget:SourceFolder%, %Widget:DestinationFolder%, %Widget:BlenderExecutable%)"
                }
              },
              {
                "AutoWidth": true,
                "SButton": {
                  "Text": "Browse",
                  "OnClick": "PEU:BrowseFile:BlenderExecutable"
                }
              }
            ]
          }
        },
        {
          "AutoHeight": true,
          "SVerticalBox": {
            "Slots": [
              {
                "AutoHeight": true,
                "Padding": [0, 0, 0, 6],
                "SBorder": {
                  "Padding": [8, 6, 8, 6],
                  "Content": {
                    "SVerticalBox": {
                      "Slots": [
                        {
                          "AutoHeight": true,
                          "STextBlock": {
                            "Text": "UV Workflow"
                          }
                        },
                        {
                          "AutoHeight": true,
                          "SUniformGridPanel": {
                            "SlotPadding": [6, 6, 6, 6],
                            "Slots": [
                              {
                                "Column_Row": [0, 0],
                                "STextBlock": {
                                  "Text": "UV 0 Unwrap Mode"
                                }
                              },
                              {
                                "Column_Row": [1, 0],
                                "SComboBox": {
                                  "Aka": "UV0UnwrapMode",
                                  "StateKey": "uv0_unwrap_mode",
                                  "Selected": "Keep Existing",
                                  "Options": [
                                    "Keep Existing",
                                    "Lightmap Pack",
                                    "Smart UV Project"
                                  ],
                                  "OnSelectionChanged": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.set_uv_workflow_options(%Widget:UV0UnwrapMode%, %Widget:UV1UnwrapMode%)"
                                }
                              },
                              {
                                "Column_Row": [2, 0],
                                "STextBlock": {
                                  "Text": "UV 1 Unwrap Mode"
                                }
                              },
                              {
                                "Column_Row": [3, 0],
                                "SComboBox": {
                                  "Aka": "UV1UnwrapMode",
                                  "StateKey": "uv1_unwrap_mode",
                                  "Selected": "Lightmap Pack",
                                  "Options": [
                                    "Lightmap Pack",
                                    "Smart UV Project"
                                  ],
                                  "OnSelectionChanged": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.set_uv_workflow_options(%Widget:UV0UnwrapMode%, %Widget:UV1UnwrapMode%)"
                                }
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                }
              },
              {
                "AutoHeight": true,
                "Padding": [0, 0, 0, 6],
                "SConditionalBox": {
                  "StateKey": "show_smart_uv_settings",
                  "VisibleWhen": true,
                  "Content": {
                    "SBorder": {
                      "Padding": [8, 6, 8, 6],
                      "Content": {
                        "SVerticalBox": {
                          "Slots": [
                            {
                              "AutoHeight": true,
                              "STextBlock": {
                                "Text": "Smart UV Project Settings"
                              }
                            },
                            {
                              "AutoHeight": true,
                              "STextBlock": {
                                "Text": "These Smart UV settings apply to any channel whose unwrap mode is Smart UV Project."
                              }
                            },
                            {
                              "AutoHeight": true,
                              "SHorizontalBox": {
                                "Slots": [
                                  {
                                    "AutoWidth": true,
                                    "Padding": [0, 0, 8, 0],
                                    "STextBlock": {
                                      "Text": "Smart UV Margin"
                                    }
                                  },
                                  {
                                    "FillWidth": 1.0,
                                    "SEditableTextBox": {
                                      "Aka": "SmartUVMargin",
                                      "StateKey": "smart_uv_margin",
                                      "Text": "0.05",
                                      "OnTextCommitted": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.set_smart_uv_settings(%Widget:SmartUVMargin%)"
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      }
                    }
                  }
                }
              },
              {
                "AutoHeight": true,
                "Padding": [0, 0, 0, 6],
                "SConditionalBox": {
                  "StateKey": "show_lightmap_pack_settings",
                  "VisibleWhen": true,
                  "Content": {
                    "SBorder": {
                      "Padding": [8, 6, 8, 6],
                      "Content": {
                        "SVerticalBox": {
                          "Slots": [
                            {
                              "AutoHeight": true,
                              "STextBlock": {
                                "Text": "Lightmap Pack Settings"
                              }
                            },
                            {
                              "AutoHeight": true,
                              "STextBlock": {
                                "Text": "These Lightmap Pack settings apply to any channel whose unwrap mode is Lightmap Pack."
                              }
                            },
                            {
                              "AutoHeight": true,
                              "SUniformGridPanel": {
                                "SlotPadding": [6, 6, 6, 6],
                                "Slots": [
                                  {
                                    "Column_Row": [0, 0],
                                    "STextBlock": {
                                      "Text": "Lightmap Pack Margin"
                                    }
                                  },
                                  {
                                    "Column_Row": [1, 0],
                                    "SEditableTextBox": {
                                      "Aka": "LightmapMargin",
                                      "StateKey": "lightmap_margin",
                                      "Text": "0.05",
                                      "OnTextCommitted": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.set_lightmap_pack_settings(%Widget:LightmapMargin%, %Widget:LightmapPackQuality%)"
                                    }
                                  },
                                  {
                                    "Column_Row": [2, 0],
                                    "STextBlock": {
                                      "Text": "Lightmap Pack Quality"
                                    }
                                  },
                                  {
                                    "Column_Row": [3, 0],
                                    "SEditableTextBox": {
                                      "Aka": "LightmapPackQuality",
                                      "StateKey": "lightmap_pack_quality",
                                      "Text": "12",
                                      "OnTextCommitted": "import PythonEditorUtility.BlenderUvFixerPipelineTool as tool; tool.set_lightmap_pack_settings(%Widget:LightmapMargin%, %Widget:LightmapPackQuality%)"
                                    }
                                  }
                                ]
                              }
                            }
                          ]
                        }
                      }
                    }
                  }
                }
              }
            ]
          }
        },
        {
          "AutoHeight": true,
          "SBorder": {
            "Padding": [8, 6, 8, 6],
            "Content": {
              "SVerticalBox": {
                "Slots": [
                  {
                    "AutoHeight": true,
                    "STextBlock": {
                      "Text": "Idle",
                      "StateKey": "progress_text"
                    }
                  },
                  {
                    "AutoHeight": true,
                    "SProgressBar": {
                      "StateKey": "progress_percent",
                      "Percent": 0.0
                    }
                  }
                ]
              }
            }
          }
        },
        {
          "AutoHeight": true,
          "SBorder": {
            "Padding": [8, 8, 8, 8],
            "Content": {
              "SMultiLineEditableTextBox": {
                "StateKey": "status_text",
                "IsReadOnly": true,
                "Text": "Loading status..."
              }
            }
          }
        },
        {
          "FillHeight": 1.0,
          "SBorder": {
            "Padding": [8, 8, 8, 8],
            "Content": {
              "SMultiLineEditableTextBox": {
                "StateKey": "detail_text",
                "IsReadOnly": true,
                "Text": "Loading details..."
              }
            }
          }
        }
      ]
    }
  }
}
